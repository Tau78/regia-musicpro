{
  "name": "regia-video",
  "description": "REGIA MUSICPRO — regia video / playlist",
  "private": true,
  "version": "0.0.16",
  "regiaProgramCreatedOn": "2026-04-18",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "author": "Regia Video",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/electron-dist-postbuild.mjs",
    "predev": "npm run build:electron",
    "dev": "concurrently -k \"vite\" \"npm run dev:electron-watch\" \"wait-on dist-electron/dev-server-url.txt dist-electron/main.cjs && electron .\"",
    "dev:electron-watch": "node scripts/tsc-electron-dev-watch.mjs",
    "dev:vite": "vite",
    "build": "tsc -b && vite build && npm run build:electron",
    "gen:launchpad-base": "node scripts/gen-launchpad-base-wavs.mjs",
    "gen:launchpad-sfx": "node scripts/gen-launchpad-sfx-wavs.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "dist:win:publish": "npm run build && electron-builder --win --x64 --publish always",
    "release:win:github": "bash scripts/publish-win-github-release.sh",
    "git:commit": "bash scripts/git-commit.sh",
    "git:commit:release-win": "bash scripts/git-commit-and-win-build.sh"
  },
  "dependencies": {
    "bonjour": "^3.5.1",
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  }
}
